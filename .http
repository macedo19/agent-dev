### Geração de Testes — POST /api/v1/tests
POST http://localhost/api/v1/tests
Content-Type: application/json

{
  "language": "TypeScript",
  "test_framework": "jest",
  "code": "export function calcularJurosSimples(\n  principal: number,\n  taxaMensal: number,\n  meses: number\n): number {\n  if (principal < 0 || taxaMensal < 0 || meses < 0) {\n    throw new Error('Parâmetros não podem ser negativos');\n  }\n  return parseFloat((principal * (1 + taxaMensal * meses)).toFixed(2));\n}\n\nexport function gerarParcelamento(\n  valorTotal: number,\n  numParcelas: number,\n  taxaMensal: number\n): { parcela: number; numero: number; valor: number }[] {\n  if (numParcelas <= 0) throw new Error('Número de parcelas deve ser positivo');\n  const totalComJuros = calcularJurosSimples(valorTotal, taxaMensal, numParcelas);\n  const valorParcela = parseFloat((totalComJuros / numParcelas).toFixed(2));\n  return Array.from({ length: numParcelas }, (_, i) => ({\n    parcela: i + 1,\n    numero: i + 1,\n    valor: valorParcela,\n  }));\n}"
}

