### Documentação Técnica — POST /api/v1/document (doc_type: technical)
POST http://localhost/api/v1/document
Content-Type: application/json

{
  "language": "Python",
  "doc_type": "technical",
  "code": "from datetime import date\nfrom typing import Literal\n\nAgeingBucket = Literal['current', '1-30', '31-60', '61-90', '91-180', '180+']\n\ndef classify_aging(due_date: date, reference_date: date | None = None) -> AgeingBucket:\n    ref = reference_date or date.today()\n    days_overdue = (ref - due_date).days\n    if days_overdue <= 0:   return 'current'\n    if days_overdue <= 30:  return '1-30'\n    if days_overdue <= 60:  return '31-60'\n    if days_overdue <= 90:  return '61-90'\n    if days_overdue <= 180: return '91-180'\n    return '180+'\n\ndef summarize_portfolio(debts: list[dict]) -> dict:\n    summary = {'current': 0, '1-30': 0, '31-60': 0, '61-90': 0, '91-180': 0, '180+': 0}\n    for debt in debts:\n        bucket = classify_aging(debt['due_date'])\n        summary[bucket] += debt['valor']\n    return summary"
}

